{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "kube-prometheus-stack Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel",      "id": "stat",       "name": "Stat",       "version": "" },
    { "type": "panel",      "id": "timeseries", "name": "Time series","version": "" },
    { "type": "panel",      "id": "table",      "name": "Table",      "version": "" },
    { "type": "panel",      "id": "gauge",      "name": "Gauge",      "version": "" },
    { "type": "panel",      "id": "barchart",   "name": "Bar chart",  "version": "" },
    { "type": "panel",      "id": "text",       "name": "Text",       "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "SRE Agent — Kubernetes Cluster Health. Current issues with root-cause + fix recommendations, historical pod lifecycle, per-pod cost, and node pressure.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🛡 Cluster Health — Current State",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "green", "index": 0, "text": "✅ HEALTHY" },
                "1": { "color": "red",   "index": 1, "text": "⚠ ISSUES"  }
              },
              "type": "value"
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Cluster Status",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "1 - sre_cluster_healthy{}", "legendFormat": "Status", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "🔴 Critical Issues",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sre_critical_issues_total{}", "legendFormat": "Critical", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 } ] }
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "🟡 Warning Issues",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sre_warning_issues_total{}", "legendFormat": "Warning", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 } ] }
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "ℹ️ Info Notices",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sre_info_issues_total{}", "legendFormat": "Info", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "🖥 Nodes Ready",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sre_nodes_ready{}", "legendFormat": "Ready", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sre_nodes_total{}", "legendFormat": "Total", "refId": "B" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 120 }, { "color": "red", "value": 180 } ] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "⏱ Last Check Age",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "time() - sre_last_check_timestamp_seconds{}", "legendFormat": "Age", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 30 } ] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "id": 7,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "⚡ Check Duration",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sre_check_duration_seconds{}", "legendFormat": "Duration", "refId": "A" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "🔥 Active Issues — with Root Cause & Fix Recommendations",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Shows only check types that currently have active issues. Root Cause, Immediate action, and Prevent guidance is joined from the sre_check_rec_info metric (populated at agent startup).\n\nPromQL: (sre_issues_by_check > 0) * on(check) group_left(root_cause,immediate,prevent) sre_check_rec_info",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "left",
            "cellOptions": { "type": "auto" },
            "inspect": true,
            "minWidth": 60,
            "wrap": true
          },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              { "id": "displayName", "value": "Severity" },
              { "id": "custom.width", "value": 110 },
              {
                "id": "mappings",
                "value": [
                  { "options": { "CRITICAL": { "color": "red",    "index": 0, "text": "🔴 CRITICAL" }, "WARNING": { "color": "yellow", "index": 1, "text": "🟡 WARNING" }, "INFO": { "color": "blue", "index": 2, "text": "ℹ️  INFO" } }, "type": "value" }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "check" },
            "properties": [
              { "id": "displayName", "value": "Check" },
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Count" },
              { "id": "custom.width", "value": 60 },
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "yellow", "value": null }, { "color": "red", "value": 1 } ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "root_cause" },
            "properties": [
              { "id": "displayName", "value": "🔍 Root Cause" },
              { "id": "custom.minWidth", "value": 300 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "immediate" },
            "properties": [
              { "id": "displayName", "value": "⚡ Immediate Action" },
              { "id": "custom.minWidth", "value": 280 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "prevent" },
            "properties": [
              { "id": "displayName", "value": "🛡 Prevent" },
              { "id": "custom.minWidth", "value": 260 }
            ]
          }
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "cellHeight": "lg",
        "footer": { "countRows": false, "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Severity" }]
      },
      "title": "Active Issues — Root Cause & Recommended Actions",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "mode": "columns" }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": ["severity", "check", "root_cause", "immediate", "prevent", "Value"]
            }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": [{ "desc": true, "displayName": "severity" }] }
        }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "(sre_issues_by_check > 0) * on(check) group_left(root_cause,immediate,prevent) sre_check_rec_info",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "📈 Issue Trends Over Time",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "gradientMode": "opacity", "lineWidth": 2, "showPoints": "auto", "spanNulls": false }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Critical" }, "properties": [ { "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "Warning" },  "properties": [ { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "Info" },     "properties": [ { "id": "color", "value": { "fixedColor": "blue",   "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 20,
      "options": {
        "legend": { "calcs": ["lastNotNull","max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Critical & Warning Issues — Trend",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sre_critical_issues_total{}", "legendFormat": "Critical", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sre_warning_issues_total{}", "legendFormat": "Warning", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sre_info_issues_total{}", "legendFormat": "Info", "refId": "C" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2, "showPoints": "auto", "spanNulls": false }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Evictions" },  "properties": [ { "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "OOMKills" },   "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "CrashLoops" }, "properties": [ { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 21,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "New Evictions / OOMKills / CrashLoops — Cumulative Counter",
      "description": "Counters only increment when a NEW issue appears for the first time. Persistent issues from prior cycles are not re-counted.",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sre_evictions_detected_total{}", "legendFormat": "Evictions", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sre_oomkills_detected_total{}", "legendFormat": "OOMKills", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sre_crashloops_detected_total{}", "legendFormat": "CrashLoops", "refId": "C" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "📦 Pod Lifecycle — Historical (kube-state-metrics)",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Running" },   "properties": [ { "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "Pending" },   "properties": [ { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "Failed" },    "properties": [ { "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "Succeeded" }, "properties": [ { "id": "color", "value": { "fixedColor": "blue",   "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 30,
      "options": {
        "legend": { "calcs": ["lastNotNull","max","min"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Pod Phases — All Namespaces",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(kube_pod_status_phase{phase=\"Running\"})",   "legendFormat": "Running",   "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(kube_pod_status_phase{phase=\"Pending\"})",   "legendFormat": "Pending",   "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(kube_pod_status_phase{phase=\"Failed\"})",    "legendFormat": "Failed",    "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(kube_pod_status_phase{phase=\"Succeeded\"})", "legendFormat": "Succeeded", "refId": "D" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": true }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 31,
      "options": {
        "legend": { "calcs": ["lastNotNull","max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Running Pods per Namespace",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (namespace) (kube_pod_status_phase{phase=\"Running\"})",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Evicted" },   "properties": [ { "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "OOMKilled" }, "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "id": 32,
      "options": {
        "legend": { "calcs": ["lastNotNull","sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Evicted & OOMKilled Pods — Historical Count",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(kube_pod_status_reason{reason=\"Evicted\"})", "legendFormat": "Evicted", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(kube_pod_container_status_last_terminated_reason{reason=\"OOMKilled\"})", "legendFormat": "OOMKilled", "refId": "B" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": true }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "id": 33,
      "options": {
        "legend": { "calcs": ["lastNotNull","max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "HPA Replicas — Scaling History",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "kube_horizontalpodautoscaler_status_current_replicas", "legendFormat": "{{namespace}}/{{horizontalpodautoscaler}} (current)", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "kube_horizontalpodautoscaler_spec_max_replicas",        "legendFormat": "{{namespace}}/{{horizontalpodautoscaler}} (max)",     "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "kube_horizontalpodautoscaler_spec_min_replicas",        "legendFormat": "{{namespace}}/{{horizontalpodautoscaler}} (min)",     "refId": "C" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "id": 108,
      "title": "🔁 Top Restarting Pods",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 } ] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" },     "properties": [ { "id": "displayName", "value": "Restarts" }, { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } }, { "id": "custom.width", "value": 100 } ] },
