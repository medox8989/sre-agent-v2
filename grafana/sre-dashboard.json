      "title": "🚀 Deployment Health",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Available" },   "properties": [ { "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "Unavailable" }, "properties": [ { "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "Desired" },     "properties": [ { "id": "color", "value": { "fixedColor": "blue",   "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "dash": [10,10], "fill": "dash" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 90 },
      "id": 70,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Deployment Replicas — Available vs Desired",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(kube_deployment_status_replicas_available{})", "legendFormat": "Available",  "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(kube_deployment_spec_replicas{})",               "legendFormat": "Desired",    "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(kube_deployment_status_replicas_unavailable{})",  "legendFormat": "Unavailable","refId": "C" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Deployments that currently have fewer available replicas than desired. These are actively degraded workloads.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "wrap": false },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "namespace" },   "properties": [ { "id": "displayName", "value": "Namespace" }, { "id": "custom.width", "value": 160 } ] },
          { "matcher": { "id": "byName", "options": "deployment" },  "properties": [ { "id": "displayName", "value": "Deployment" } ] },
          { "matcher": { "id": "byName", "options": "Value" },       "properties": [ { "id": "displayName", "value": "Unavailable" }, { "id": "custom.width", "value": 110 }, { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 90 },
      "id": 71,
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Value" }]
      },
      "title": "Deployments with Unavailable Replicas",
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "filterFieldsByName", "options": { "include": { "names": ["namespace","deployment","Value"] } } },
        { "id": "filterByValue", "options": { "filters": [{ "config": { "id": "greater", "options": { "value": 0 } }, "fieldName": "Value" }], "match": "all", "type": "include" } }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "kube_deployment_status_replicas_unavailable{} > 0",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    }

