    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Actual CPU usage (not requests). Uses cAdvisor metrics scraped by kube-prometheus-stack. Shows top 10 pods by real consumption — useful for spotting runaway processes and cost attribution.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "unit": "short"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 54 },
      "id": 50,
      "options": {
        "legend": { "calcs": ["mean","max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Top 10 Pods — CPU Usage (actual cores)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(10, sum by (namespace, pod) (rate(container_cpu_usage_seconds_total{container!=\"POD\",container!=\"\",namespace!~\"kube-system|monitoring\"}[5m])))",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Actual memory working set. Top 10 pods by real memory consumption — use this to find memory leaks and right-size your resource limits.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 54 },
      "id": 51,
      "options": {
        "legend": { "calcs": ["mean","max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Top 10 Pods — Memory Usage (actual bytes)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(10, sum by (namespace, pod) (container_memory_working_set_bytes{container!=\"POD\",container!=\"\",namespace!~\"kube-system|monitoring\"}))",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "CPU usage (actual cores) grouped by namespace over time. Use the time range selector to see last week or last month.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "gradientMode": "opacity", "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 63 },
      "id": 53,
      "options": {
        "legend": { "calcs": ["mean","max","lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "CPU Usage by Namespace (actual) — Historical",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (namespace) (rate(container_cpu_usage_seconds_total{container!=\"POD\",container!=\"\"}[5m]))",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Memory usage (actual bytes) grouped by namespace over time. Use the time range selector to see last week or last month.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "gradientMode": "opacity", "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 63 },
      "id": 54,
      "options": {
        "legend": { "calcs": ["mean","max","lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Memory Usage by Namespace (actual) — Historical",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (namespace) (container_memory_working_set_bytes{container!=\"POD\",container!=\"\"})",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Estimated monthly cost per namespace based on CPU + memory REQUESTS. Formula: (cpu_cores × $0.025/hr + mem_GiB × $0.0015/hr) × 720 hours/month. Adjust multipliers to match your OCI node shape pricing.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 } ] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "namespace" },          "properties": [ { "id": "displayName", "value": "Namespace" }, { "id": "custom.width", "value": 180 } ] },
          { "matcher": { "id": "byName", "options": "CPU Req (m)" },        "properties": [ { "id": "displayName", "value": "CPU Request (m)" }, { "id": "unit", "value": "short" }, { "id": "custom.width", "value": 120 }, { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ {"color":"green","value":null}, {"color":"yellow","value":2000}, {"color":"red","value":8000} ] } } ] },
          { "matcher": { "id": "byName", "options": "Mem Req (Mi)" },       "properties": [ { "id": "displayName", "value": "Memory Request (Mi)" }, { "id": "unit", "value": "short" }, { "id": "custom.width", "value": 140 }, { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ {"color":"green","value":null}, {"color":"yellow","value":4096}, {"color":"red","value":16384} ] } } ] },
          { "matcher": { "id": "byName", "options": "Est $/month" },        "properties": [ { "id": "displayName", "value": "Est. Cost/Month (USD)" }, { "id": "unit", "value": "currencyUSD" }, { "id": "custom.width", "value": 160 }, { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } } ] }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 71 },
      "id": 52,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "reducer": ["sum"], "show": true, "fields": ["CPU Req (m)", "Mem Req (Mi)", "Est $/month"] },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Est $/month" }]
      },
      "title": "Resource Requests & Estimated Monthly Cost by Namespace (snapshot)",
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "filterFieldsByName", "options": { "include": { "names": ["namespace","Value #A","Value #B","Value #C"] } } },
        { "id": "joinByField", "options": { "byField": "namespace", "mode": "outer" } },
        { "id": "organize", "options": { "renameByName": { "Value #A": "CPU Req (m)", "Value #B": "Mem Req (Mi)", "Value #C": "Est $/month" } } }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (namespace) (kube_pod_container_resource_requests{resource=\"cpu\"}) * 1000",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (namespace) (kube_pod_container_resource_requests{resource=\"memory\"}) / 1024 / 1024",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "(sum by (namespace) (kube_pod_container_resource_requests{resource=\"cpu\"}) * 0.025 + sum by (namespace) (kube_pod_container_resource_requests{resource=\"memory\"}) / 1024 / 1024 / 1024 * 0.0015) * 720",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "C"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 80 },
      "id": 106,
      "title": "🖥 Node Resource Pressure",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "How much total memory limits exceed node allocatable memory. >100% means OOM kills are possible if all pods hit their limits simultaneously.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 200,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "orange", "value": 120 }, { "color": "red", "value": 150 } ] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 81 },
      "id": 60,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "Memory Limit Overcommit % per Node",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (node) (kube_pod_container_resource_limits{resource=\"memory\"}) / on(node) kube_node_status_allocatable{resource=\"memory\"} * 100",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "How much total CPU limits exceed node allocatable CPU. >100% means CPU throttling under load.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 200,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "orange", "value": 120 }, { "color": "red", "value": 150 } ] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 81 },
      "id": 61,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "CPU Limit Overcommit % per Node",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (node) (kube_pod_container_resource_limits{resource=\"cpu\"}) / on(node) kube_node_status_allocatable{resource=\"cpu\"} * 100",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Number of Running pods per node over time. An uneven distribution can indicate a scheduling or resource problem.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": true }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 81 },
      "id": 62,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Pods per Node — Running",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (node) (\n  kube_pod_info{node!=\"\"}\n  * on(pod, namespace) group_left()\n  kube_pod_status_phase{phase=\"Running\"}\n)",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 89 },
