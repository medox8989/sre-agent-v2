      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "CPU Request (m)",
              "Value #B": "Mem Request (Mi)",
              "Value #C": "Est. Cost/Mo (USD)",
              "namespace": "Namespace"
            }
          }
        }
      ],
