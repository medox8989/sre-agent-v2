      "description": "Active PostgreSQL backend connections = database sessions open right now. Each Odoo HTTP worker that is processing a request holds one or more DB connections.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
