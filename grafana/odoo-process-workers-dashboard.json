  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "text",
      "name": "Text",
      "version": ""
    }
  ],
  "description": "Odoo worker PROCESS visibility \u2014 HTTPWorker, CronWorker, GeventWorker counts per node, CPU/memory per worker type, worker age, dead-worker detection. Requires process-exporter DaemonSet (k8s/08-process-exporter.yaml).",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 200,
      "type": "text",
      "title": "\u2139\ufe0f How Odoo Workers Appear in /proc",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "**Odoo does not use `setproctitle`** \u2014 master process, HTTP workers, and cron worker all share an identical cmdline (`/usr/bin/python3 /usr/bin/odoo -c <config>`). Only the **gevent/longpolling worker** is distinguishable (has `gevent` as an argument).\n\n| Group | Count | What it contains |\n|---|---|---|\n| `odoo_workers` | workers + 2 | 1 master + N HTTP workers + 1 cron |\n| `odoo_gevent` | 1 | Longpolling / bus / live-chat worker |\n\n**HTTP worker count estimate** = `odoo_workers \u2212 2`. With `workers = 7` \u2192 expect **9** in `odoo_workers` group."
      },
      "datasource": null,
      "transparent": false
    },
    {
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "id": 200,
      "options": {
        "content": "<div style=\"font-family:monospace;font-size:11px;padding:6px 10px;background:#161b22;border-left:3px solid #58a6ff;border-radius:4px\">\n<b style=\"color:#79c0ff\">\u2139\ufe0f How to read this dashboard:</b>&nbsp;&nbsp;\nEach row = one node running Odoo. Each column = one worker TYPE (not one pod).<br>\nOdoo with <code>--workers 4</code> \u2192 1 master + 4 HTTPWorker + 1 CronWorker + 1 GeventWorker = 7 OS processes per pod.<br>\n<b style=\"color:#f85149\">Worker count drop below expected</b> = a worker crashed and Odoo master has not yet replaced it.<br>\nFilter by <b>Node</b> to isolate a specific Odoo deployment (if each deployment is on its own node).\nFor per-namespace breakdown deploy the <b>sidecar</b> (see k8s/08-process-exporter.yaml).\n</div>",
        "mode": "html"
      },
      "title": "",
      "type": "text"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 100,
      "title": "\ud83d\udc77 Odoo Worker Process Fleet \u2014 Live Counts",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Estimated HTTP worker count = total Odoo processes minus master and cron (\u00f72 overhead). Formula: odoo_workers \u2212 2. With workers=7, expect 7 here.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 7
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "text": {
          "titleSize": 12,
          "valueSize": 36
        }
      },
      "title": "HTTP Workers (est.)",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "clamp_min(sum(namedprocess_namegroup_num_procs{groupname=\"odoo_workers\", node=~\"$node\"}) - 2, 0)",
          "instant": true,
          "refId": "A",
          "legendFormat": "__auto"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Odoo forks exactly 1 cron worker. It cannot be isolated via /proc \u2014 all workers share the same cmdline. Expected value: always 1.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 4,
        "y": 7
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "text": {
          "titleSize": 12,
          "valueSize": 36
        }
      },
      "title": "Cron Worker",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "vector(1)",
          "instant": true,
          "refId": "A",
          "legendFormat": "__auto"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Longpolling / bus / live-chat worker. Unique because it passes 'gevent' as an argument.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 8,
        "y": 7
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "text": {
          "titleSize": 12,
          "valueSize": 36
        }
      },
      "title": "Gevent Worker",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(namedprocess_namegroup_num_procs{groupname=\"odoo_gevent\", node=~\"$node\"}) or vector(0)",
          "instant": true,
          "refId": "A",
          "legendFormat": "__auto"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "All non-gevent Odoo processes: master + HTTP workers + cron. With workers=7 expect 9 (1 master + 7 HTTP + 1 cron).",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "blue",
                "value": 1
              }
