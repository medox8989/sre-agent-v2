          "legendFormat": "Postgres backends",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "id": 102,
      "title": "\ud83d\udda5\ufe0f CPU Consumption Per Worker Type",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "CPU seconds per second per worker type per node. This shows which WORKER TYPE is consuming CPU \u2014 not the aggregate pod CPU. HTTP workers spiking = heavy user requests. Cron worker spiking = background job running.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          }
        }
