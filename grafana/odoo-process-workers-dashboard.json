      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "text": {
          "titleSize": 12,
          "valueSize": 36
        }
      },
      "title": "HTTP Workers (est.) / Node",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "clamp_min(namedprocess_namegroup_num_procs{groupname=\"odoo_workers\", node=~\"$node\"} - 2, 0)",
          "instant": true,
          "refId": "A",
          "legendFormat": "__auto"
