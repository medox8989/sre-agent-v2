      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 7
      },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "text": {
          "titleSize": 12,
          "valueSize": 36
