          "expr": "rate(namedprocess_namegroup_cpu_seconds_total{groupname=\"odoo_workers\", node=~\"$node\"}[$__rate_interval]) / clamp_min(namedprocess_namegroup_num_procs{groupname=\"odoo_workers\", node=~\"$node\"} - 2, 1)",
