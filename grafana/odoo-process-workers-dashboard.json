          }
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 12,
        "y": 7
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "text": {
          "titleSize": 12,
          "valueSize": 36
        }
      },
      "title": "Total Odoo Processes",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(namedprocess_namegroup_num_procs{groupname=\"odoo_workers\", node=~\"$node\"}) or vector(0)",
          "instant": true,
          "refId": "A",
          "legendFormat": "__auto"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Estimated HTTP worker count per node = odoo_workers group size \u2212 2.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
