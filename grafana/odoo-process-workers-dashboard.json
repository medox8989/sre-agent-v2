    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 101,
      "title": "\ud83d\udcca Worker Count Over Time \u2014 Dead Worker Detection",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Total odoo_workers (master+HTTP+cron). Expected = workers_setting + 2. A sudden drop means a worker crashed.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          }
        }
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "id": 10,
      "options": {
        "legend": {
          "calcs": [
            "min",
            "max",
            "last"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "Odoo Worker Count Over Time \u2014 Per Node (drop = workers died)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "namedprocess_namegroup_num_procs{groupname=\"odoo_workers\", node=~\"$node\"}",
          "legendFormat": "All workers (master+HTTP+cron)",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "namedprocess_namegroup_num_procs{groupname=\"odoo_gevent\", node=~\"$node\"}",
          "legendFormat": "Gevent",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "All worker types on one chart per node. Healthy: HTTP count stable, Cron=1, Gevent=1 per deployment. Any type dropping to 0 = that worker type died.",
      "fieldConfig": {
        "defaults": {
