{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat",       "name": "Stat",       "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series","version": "" },
    { "type": "panel", "id": "table",      "name": "Table",      "version": "" },
    { "type": "panel", "id": "bargauge",   "name": "Bar gauge",  "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "K8s Warning Events — mirrors the SRE agent --events CLI with ACTIVE / RECENT / HISTORY buckets, full object + message detail",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🔥 Event Timeline — Now",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "dark-red" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "pluginVersion": "9.0.0",
      "title": "🔴 ACTIVE  (last 5 min)",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(sre_namespace_events{bucket=\"ACTIVE\",namespace=~\"$namespace\"})", "instant": true, "legendFormat": "Active", "refId": "A" }],
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "dark-yellow" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }] },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "pluginVersion": "9.0.0",
      "title": "🟡 RECENT  (5–30 min)",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(sre_namespace_events{bucket=\"RECENT\",namespace=~\"$namespace\"})", "instant": true, "legendFormat": "Recent", "refId": "A" }],
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "blue", "value": 1 }] },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "pluginVersion": "9.0.0",
      "title": "🔵 HISTORY  (30 min–6 h)",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(sre_namespace_events{bucket=\"HISTORY\",namespace=~\"$namespace\"})", "instant": true, "legendFormat": "History", "refId": "A" }],
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "pluginVersion": "9.0.0",
      "title": "⚠ Incident Patterns",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(sre_issues_by_check{check=~\"HPAFlapping|CNINotReady|HPAMetricLag|NodeScaleDelay\",namespace=~\"$namespace\"} > 0) OR vector(0)", "instant": true, "legendFormat": "Incidents", "refId": "A" }],
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "pluginVersion": "9.0.0",
      "title": "🚨 CRITICAL Issues",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sre_critical_issues", "instant": true, "legendFormat": "Critical", "refId": "A" }],
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "yellow" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }] },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "pluginVersion": "9.0.0",
      "title": "⚠ WARNING Issues",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sre_warning_issues", "instant": true, "legendFormat": "Warning", "refId": "A" }],
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "📋 Event Log  (ACTIVE → RECENT → HISTORY)",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "displayMode": "auto", "inspect": false, "minWidth": 50 },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.width", "value": 115 },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "mappings",
                "value": [{
                  "options": {
                    "ACTIVE":  { "color": "dark-red",   "index": 0, "text": "🔴 ACTIVE"  },
                    "RECENT":  { "color": "dark-yellow", "index": 1, "text": "🟡 RECENT"  },
                    "HISTORY": { "color": "dark-blue",   "index": 2, "text": "🔵 HISTORY" }
                  },
                  "type": "value"
                }]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Namespace" },
            "properties": [
              { "id": "custom.width", "value": 120 },
              { "id": "custom.displayMode", "value": "color-text" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Reason" },
            "properties": [
              { "id": "custom.width", "value": 180 },
              { "id": "custom.displayMode", "value": "color-text" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Kind" },
            "properties": [{ "id": "custom.width", "value": 90 }]
          },
          {
            "matcher": { "id": "byName", "options": "Object" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          },
          {
            "matcher": { "id": "byName", "options": "Description" },
            "properties": [
              { "id": "custom.width", "value": 500 },
              { "id": "custom.inspect", "value": true }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Count" },
            "properties": [
              { "id": "custom.width", "value": 70 },
              { "id": "custom.displayMode", "value": "color-background-solid" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 3 },
                    { "color": "red",    "value": 10 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "footer": { "enablePagination": true, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Status" }]
      },
      "pluginVersion": "9.0.0",
      "title": "Warning Events — Full Detail",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "mode": "columns", "valueLabel": "Count" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "__name__":     true,
              "Time":         true,
              "container":    true,
              "endpoint":     true,
              "exported_name":true,
              "instance":     true,
              "job":          true,
              "pod":          true,
              "service":      true
            },
            "indexByName": {
              "bucket":    0,
              "namespace": 1,
              "reason":    2,
              "kind":      3,
              "object":    4,
              "message":   5,
              "Count":     6
            },
            "renameByName": {
              "bucket":    "Status",
              "namespace": "Namespace",
              "reason":    "Reason",
              "kind":      "Kind",
              "object":    "Object",
              "message":   "Description",
              "Count":     "Count"
            }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": [{ "desc": false, "displayName": "Status" }] }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sre_event_detail{namespace=~\"$namespace\"} > 0",
          "format": "table",
          "instant": true,
          "legendFormat": "{{namespace}}/{{reason}}/{{object}}",
          "refId": "A"
        }
      ],
      "type": "table"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "📈 Event Trends",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth",
            "lineWidth": 2, "showPoints": "never", "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 23 },
      "id": 20,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "9.0.0",
      "title": "Warning Events Over Time by Reason",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (reason) (sre_event_by_reason{namespace=~\"$namespace\"})",
        "legendFormat": "{{reason}}", "refId": "A"
      }],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "orange", "value": 8 },
              { "color": "red",    "value": 15 }
            ]
          },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "id": 21,
      "options": {
        "displayMode": "gradient", "minVizHeight": 10, "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "pluginVersion": "9.0.0",
      "title": "Active + Recent Events by Namespace",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (namespace) (sre_namespace_events{bucket=~\"ACTIVE|RECENT\",namespace=~\"$namespace\"})",
        "instant": true, "legendFormat": "{{namespace}}", "refId": "A"
      }],
      "type": "bargauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth",
            "lineWidth": 1, "showPoints": "never", "spanNulls": true,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 31 },
      "id": 22,
      "options": {
        "legend": { "calcs": ["max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "9.0.0",
      "title": "Events per Namespace Over Time (Stacked)",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (namespace) (sre_namespace_events{namespace=~\"$namespace\"})",
        "legendFormat": "{{namespace}}", "refId": "A"
      }],
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 103,
      "title": "🔍 Incident Patterns  (HPAFlapping · CNINotReady · HPAMetricLag · NodeScaleDelay)",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "displayMode": "auto", "inspect": false },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "check" },
            "properties": [
              { "id": "custom.width", "value": 200 },
              { "id": "custom.displayMode", "value": "color-text" },
              {
                "id": "mappings",
                "value": [{
                  "options": {
                    "HPAFlapping":    { "color": "orange", "index": 0, "text": "⚡ HPAFlapping"    },
                    "CNINotReady":    { "color": "red",    "index": 1, "text": "🔌 CNINotReady"    },
                    "HPAMetricLag":   { "color": "yellow", "index": 2, "text": "📊 HPAMetricLag"   },
                    "NodeScaleDelay": { "color": "purple", "index": 3, "text": "🐢 NodeScaleDelay" }
                  },
                  "type": "value"
                }]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "mappings",
                "value": [{
                  "options": {
                    "CRITICAL": { "color": "red",    "index": 0, "text": "🚨 CRITICAL" },
                    "WARNING":  { "color": "yellow", "index": 1, "text": "⚠ WARNING"  },
                    "INFO":     { "color": "blue",   "index": 2, "text": "ℹ INFO"     }
                  },
                  "type": "value"
                }]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "custom.width", "value": 70 },
              { "id": "custom.displayMode", "value": "color-background-solid" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "id": 30,
      "options": { "footer": { "show": false }, "showHeader": true },
      "pluginVersion": "9.0.0",
      "title": "Incident Patterns Detected",
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns", "valueLabel": "Value" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "__name__": true, "container": true, "endpoint": true, "exported_name": true, "instance": true, "job": true, "pod": true, "service": true, "Time": true },
            "indexByName": { "check": 0, "severity": 1, "Value": 2 },
            "renameByName": {}
          }
        }
      ],
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sre_issues_by_check{check=~\"HPAFlapping|CNINotReady|HPAMetricLag|NodeScaleDelay\",namespace=~\"$namespace\"} > 0",
        "format": "table", "instant": true, "legendFormat": "{{check}}", "refId": "A"
      }],
      "type": "table"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "displayMode": "auto", "inspect": false },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5 }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Reason" },
            "properties": [{ "id": "custom.width", "value": 220 }]
          },
          {
            "matcher": { "id": "byName", "options": "Total" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "custom.displayMode", "value": "color-background-solid" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 10 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "id": 31,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Total" }] },
      "pluginVersion": "9.0.0",
      "title": "Top Warning Reasons",
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns", "valueLabel": "Total" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "__name__": true, "bucket": true, "namespace": true, "container": true, "endpoint": true, "exported_name": true, "instance": true, "job": true, "pod": true, "service": true, "Time": true },
            "indexByName": { "reason": 0, "Total": 1 },
            "renameByName": { "reason": "Reason", "Total": "Total" }
          }
        },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "Reason": { "aggregations": [], "operation": "groupby" },
              "Total":  { "aggregations": ["sum"], "operation": "aggregate" }
            }
          }
        },
        { "id": "sortBy", "options": { "fields": [{ "desc": true, "displayName": "Total (sum)" }] } }
      ],
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (namespace, reason, bucket) (sre_event_by_reason{namespace=~\"$namespace\"}) > 0",
        "format": "table", "instant": true, "legendFormat": "{{reason}}", "refId": "A"
      }],
      "type": "table"
    }

  ],

  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["sre-agent", "k8s", "events"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(sre_event_detail, namespace)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "namespace",
        "options": [],
        "query": {
          "query": "label_values(sre_event_detail, namespace)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "label": "Namespace",
        "allValue": ".+",
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
