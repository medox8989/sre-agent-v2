        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(sre_namespace_events{bucket=\"RECENT\",namespace=~\"$namespace\"})",
          "instant": true,
          "legendFormat": "Recent",
          "refId": "A"
        }
      ],
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
