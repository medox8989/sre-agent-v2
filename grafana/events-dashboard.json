          "values": false
        },
        "text": {},
        "textMode": "auto"
      },
      "pluginVersion": "9.0.0",
      "title": "⚠ Incident Patterns Detected",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(sre_issues_by_check{check=~\"HPAFlapping|CNINotReady|HPAMetricLag|NodeScaleDelay\",namespace=~\"$namespace\"} > 0) OR vector(0)",
          "instant": true,
          "legendFormat": "Incidents",
          "refId": "A"
        }
      ],
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
