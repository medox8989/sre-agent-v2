    {
      "id": 400,
      "type": "text",
      "title": "What is overlay storage?",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "options": {
        "mode": "markdown",
        "content": "Every container gets a **writable overlay layer** on top of its image. In OKE/containerd this lives at `/var/lib/containerd/io.containerd.snapshotter.v1.overlayfs/`. It grows when Odoo writes to any path NOT on a mounted volume: `/tmp`, `/var/log/odoo/` (if not on PVC), session files, addons cache, etc.\n\n**High overlay = risk**: fills the node's root disk, not your PVC \u2192 node runs out of disk space \u2192 all pods on that node evicted. Fix: mount a volume for `/var/log/odoo` and `/tmp` or reduce Odoo log verbosity."
      },
      "datasource": null
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Overlay Size Over Time \u2014 Per Namespace",
      "description": "container_fs_usage_bytes = writable layer size (what the container wrote above the image). Each namespace's Odoo container overlay. Rising = Odoo is writing to unvolume'd paths.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 30
      },
      "targets": [
        {
          "expr": "sum by (namespace)(container_fs_usage_bytes{namespace=~\"$namespace\",container=~\"$container\",container!=\"\",container!=\"POD\"})",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "min",
            "max",
            "last"
          ]
        }
      },
      "datasource": {
        "type": "prometheus"
      }
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "Overlay Growth Rate (bytes/hour)",
      "description": "Rate of overlay growth per namespace. Sustained >0 = files accumulating (logs, tmp, cache). Zero = overlay is stable (writes go to volumes).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 30
      },
      "targets": [
        {
          "expr": "sum by (namespace)(rate(container_fs_usage_bytes{namespace=~\"$namespace\",container=~\"$container\",container!=\"\",container!=\"POD\"}[1h]) * 3600)",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "min",
            "max",
            "last"
          ]
        }
      },
      "datasource": {
        "type": "prometheus"
      }
    },
    {
      "id": 43,
      "type": "table",
      "title": "Overlay Usage \u2014 All Pods (instant snapshot)",
      "description": "Sorted by overlay size. Identify which specific pod is consuming the most writable layer space.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 38
      },
      "targets": [
        {
          "expr": "container_fs_usage_bytes{namespace=~\"$namespace\",container=~\"$container\",container!=\"\",container!=\"POD\"}",
          "legendFormat": "Overlay Bytes",
          "refId": "A",
          "instant": true,
          "range": false
        },
        {
          "expr": "container_fs_limit_bytes{namespace=~\"$namespace\",container=~\"$container\",container!=\"\",container!=\"POD\"}",
          "legendFormat": "Overlay Limit",
          "refId": "B",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true
          }
        }
      },
      "options": {
        "footer": {
          "show": false
        }
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "id": true,
              "metrics_path": true,
              "endpoint": true,
              "node": true,
              "service": true
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "displayName": "Overlay Bytes",
                "desc": true
              }
            ]
          }
        }
      ],
      "datasource": {
        "type": "prometheus"
      }
    },
